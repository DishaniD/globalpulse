# GlobalPulse Environment Variables
# Copy this file to .env.local and fill in your API keys

# News API - Get your key at https://www.thenewsapi.com/
THE_NEWS_API_KEY=your_thenewsapi_key_here

# Anthropic Claude API - Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI DALL-E API - Get your key at https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# App Config
NEXT_PUBLIC_APP_NAME=GlobalPulse
NEXT_PUBLIC_APP_URL=http://localhost:3000
